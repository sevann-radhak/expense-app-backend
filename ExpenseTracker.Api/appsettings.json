{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "OpenApi": {
    "DocumentName": "v1",
    "Title": "Expense Tracker API",
    "Version": "v1",
    "Description": "Expense tracker API: auth (JWT), users, dev book seeding, health.",
    "SecuritySchemeId": "bearer",
    "SecuritySchemeDescription": "JWT Authorization header using the Bearer scheme.",
    "SwaggerJsonPath": "/swagger/v1/swagger.json",
    "SwaggerUiDocumentTitle": "Expense Tracker API v1"
  },
  "Api": {
    "HealthStatus": "ok",
    "HealthServiceName": "expense-tracker-api",
    "HelloMessage": "Hello, world!",
    "LogWhenDatabaseDisabled": true
  },
  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5057",
      "http://localhost:8080",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:5057",
      "http://127.0.0.1:8080"
    ]
  },
  "Entra": {
    "Enabled": false,
    "Authority": "",
    "Audience": ""
  },
  "Jwt": {
    "Issuer": "ExpenseTracker",
    "Audience": "ExpenseTracker",
    "SigningKey": "",
    "AccessTokenMinutes": 120,
    "MinimumSigningKeyLength": 32,
    "DevelopmentFallbackSigningKey": "",
    "ClockSkewMinutes": 1
  },
  "Identity": {
    "Password": {
      "RequiredLength": 8,
      "RequireDigit": true,
      "RequireNonAlphanumeric": false,
      "RequireUppercase": false,
      "RequireLowercase": false
    },
    "User": {
      "RequireUniqueEmail": true
    },
    "SignIn": {
      "RequireConfirmedEmail": false
    },
    "Lockout": {
      "AllowedForNewUsers": true,
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutTimeSpan": "00:15:00"
    }
  },
  "InitialAdmin": {
    "Enabled": false,
    "Email": "",
    "Password": ""
  },
  "Setup": {
    "BootstrapToken": ""
  },
  "DevData": {
    "ExposeEndpoints": false,
    "RequireSharedSecret": false,
    "SharedSecret": ""
  }
}
